{
  "name": "catalyst-education",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build --mode production",
    "build:windows": "set NODE_OPTIONS=--max-old-space-size=4096 && vite build",
    "build:staging": "NODE_ENV=staging vite build",
    "build:production": "NODE_ENV=production vite build",
    "preview": "vite preview",
    "start": "npx serve -s dist -l ${PORT:-10000}",
    "test": "vitest --run",
    "test:watch": "vitest",
    "format.fix": "prettier --write .",
    "typecheck": "tsc",
    "lint": "eslint src --ext .ts,.tsx --report-unused-disable-directives --max-warnings 0",
    "deploy:render": "npm run build && echo 'Ready for Render deployment'",
    "health-check": "curl -f http://localhost:10000/health.json || exit 1",
    "setup:database": "node scripts/setup-database.mjs",
    "setup:auth": "node scripts/configure-auth.mjs",
    "setup:templates": "node scripts/configure-auth.mjs --templates",
    "setup:all": "npm run setup:database && npm run setup:auth",
    "postinstall": "echo '\\n🎓 Catalyst Setup Complete!\\n  Run: npm run setup:all\\n  Then: npm run dev\\n'"
  },
  "dependencies": {
